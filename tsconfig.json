{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "allowJs": true,
    "declaration": true,
    "strict": true,
    "rootDir": "./src",
    "outDir": "./lib",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "removeComments": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "example.js",
    "example.ts",
    "icon.ts",
    "node_modules",
    "dist",
    "lib",
    ".venv",
    ".claude"
  ]
}
